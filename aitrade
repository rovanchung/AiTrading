def menu_main():
    """Top-level interactive menu."""
    while True:
        choice = pick_menu("AiTrading", [
            {"label": "Dry run",        "desc": "Scan and analyze, no trades",     "value": "dry-run"},
            {"label": "Run once",       "desc": "One full scan-analyze-trade cycle","value": "once"},
            {"label": "Run continuous", "desc": "Start trading scheduler",          "value": "run"},
            {"label": "Dashboard",      "desc": "Launch web UI",                    "value": "dashboard"},
            {"label": "Scan",           "desc": "Manual scan, show candidates",     "value": "scan"},
            {"label": "Database",       "desc": "Query positions, orders, PnL",     "value": "db"},
            {"label": "Logs",           "desc": "View application or trade logs",   "value": "logs"},
            {"label": "Setup",          "desc": "Install deps, API keys, database", "value": "setup"},
            {"label": "Info",           "desc": "Detailed reference guide",         "value": "info"},
            {"label": "Exit",           "desc": "",                                 "value": "exit"},
        ])

        if choice is None or choice == "exit":
            return

        if choice == "dry-run":
            menu_trading_mode("dry-run")
        elif choice == "once":
            menu_trading_mode("once")
        elif choice == "run":
            menu_trading_mode("run")
        elif choice == "dashboard":
            show_command(["dashboard"])
            cmd_dashboard([])
        elif choice == "scan":
            menu_scan()
        elif choice == "db":
            menu_db()
        elif choice == "logs":
            menu_logs()
        elif choice == "setup":
            menu_setup()
        elif choice == "info":
            cmd_info([])


def menu_trading_mode(mode):
    """Pick macro on/off for a trading mode."""
    choice = pick_menu(f"{mode} — Macro Overlay", [
        {"label": "With macro",    "desc": "Adjust thresholds based on economic conditions", "value": "macro"},
        {"label": "Without macro", "desc": "Use base config values as-is",                  "value": "no-macro"},
    ], back_label="Back")

    if choice is None:
        return

    args = ["--no-macro"] if choice == "no-macro" else []
    cmd_parts = [mode] + args
    show_command(cmd_parts)

    if mode == "dry-run":
        cmd_dry_run(args)
    elif mode == "once":
        cmd_once(args)
    elif mode == "run":
        cmd_run(args)


