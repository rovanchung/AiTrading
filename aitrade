# ── Arrow-key menu ──────────────────────────────────────────────────────────

def pick_menu(title, items, *, back_label=None):
    """Arrow-key menu. Returns the selected item dict or None (back/quit).

    Each item: {"label": str, "desc": str, "value": any}
    """
    import tty
    import termios

    if back_label:
        items = list(items) + [{"label": back_label, "desc": "", "value": None}]

    idx = 0
    fd = sys.stdin.fileno()
    old = termios.tcgetattr(fd)

    menu_lines = len(items) + 2   # items + blank + hint
    title_lines = 2               # title + blank
    total_lines = title_lines + menu_lines

    max_label = max(len(item["label"]) for item in items)

    def render():
        out = []
        for i, item in enumerate(items):
            raw_label = item["label"]
            pad = " " * (max_label - len(raw_label))
            if i == idx:
                pointer = f"{CYAN}>{RESET}"
                label = f"{WHITE}{BOLD}{raw_label}{RESET}{pad}"
            else:
                pointer = " "
                label = f"{raw_label}{pad}"
            desc = f"  {DIM}{item['desc']}{RESET}" if item.get("desc") else ""
            out.append(f"  {pointer} {label}{desc}")
        out.append("")
        out.append(f"  {DIM}↑/↓ navigate  Enter select  q quit{RESET}")
        return out

    def draw(first=False):
        """Clear previous menu lines and redraw. On first call, just draw."""
        if not first:
            sys.stdout.write(f"\033[{menu_lines}A")
        for line in render():
            sys.stdout.write(f"\r{CLEAR_LINE}{line}\r\n")
        sys.stdout.flush()

    def erase_all():
        """Erase the entire block including title."""
        sys.stdout.write(f"\033[{total_lines}A")
        for _ in range(total_lines):
            sys.stdout.write(f"\r{CLEAR_LINE}\r\n")
        sys.stdout.write(f"\033[{total_lines}A")

    def read_key():
        ch = sys.stdin.read(1)
        if ch == "\x1b":
            seq = sys.stdin.read(2)
            if seq == "[A":
                return "up"
            elif seq == "[B":
                return "down"
            return None
        elif ch in ("\r", "\n"):
            return "enter"
        elif ch in ("q", "Q", "\x03"):  # q or Ctrl-C
            return "quit"
        return None

    try:
        # Print title once before raw mode
        sys.stdout.write(f"  {BOLD}{title}{RESET}\n\n")
        sys.stdout.flush()
        tty.setraw(fd)
        sys.stdout.write(HIDE_CURSOR)
        draw(first=True)

        while True:
            key = read_key()
            if key == "up":
                idx = (idx - 1) % len(items)
            elif key == "down":
                idx = (idx + 1) % len(items)
            elif key == "enter":
                erase_all()
                sys.stdout.write(SHOW_CURSOR)
                sys.stdout.flush()
                termios.tcsetattr(fd, termios.TCSADRAIN, old)
                return items[idx]["value"]
            elif key == "quit":
                erase_all()
                sys.stdout.write(SHOW_CURSOR)
                sys.stdout.flush()
                termios.tcsetattr(fd, termios.TCSADRAIN, old)
                return None
            else:
                continue

            draw()

    except (KeyboardInterrupt, EOFError):
        sys.stdout.write(SHOW_CURSOR)
        sys.stdout.flush()
        termios.tcsetattr(fd, termios.TCSADRAIN, old)
        return None


def pick_yes_no(prompt):
    """Simple arrow-key yes/no picker."""
    result = pick_menu(prompt, [
        {"label": "Yes", "desc": "", "value": True},
        {"label": "No", "desc": "", "value": False},
    ])
    return result is True


def input_prompt(prompt, default=""):
    """Simple input with optional default."""
    suffix = f" [{default}]" if default else ""
    val = input(f"  {prompt}{suffix}: ").strip()
    return val or default


