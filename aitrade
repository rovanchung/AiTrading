# ── CLI dispatch ────────────────────────────────────────────────────────────

def cli_main():
    # Graceful Ctrl-C everywhere
    signal.signal(signal.SIGINT, lambda *_: (print(f"\n{SHOW_CURSOR}"), sys.exit(0)))

    if len(sys.argv) < 2:
        # Interactive mode
        print(f"\n  {BOLD}AiTrading{RESET}  {DIM}Interactive Mode{RESET}")
        print(f"  {DIM}Tip: run ./aitrade <command> to skip this menu{RESET}")
        menu_main()
        return

    command = sys.argv[1]
    rest = sys.argv[2:]

    dispatch = {
        "run":       cmd_run,
        "once":      cmd_once,
        "dry-run":   cmd_dry_run,
        "dashboard": cmd_dashboard,
        "scan":      cmd_scan,
        "setup-db":  cmd_setup_db,
        "install":   cmd_install_deps,
        "logs":      cmd_logs,
        "db":        cmd_db,
        "info":      cmd_info,
        "help":      lambda _: print(__doc__),
        "--help":    lambda _: print(__doc__),
        "-h":        lambda _: print(__doc__),
    }

    fn = dispatch.get(command)
    if fn:
        fn(rest)
    else:
        print(f"  Unknown command: {command}\n")
        print(__doc__)
        sys.exit(1)


if __name__ == "__main__":
    cli_main()
