def cmd_configure_env(_args):
    """Configure API keys in .env file."""
    env_file = os.path.join(PROJECT_ROOT, ".env")
    existing = {}
    if os.path.isfile(env_file):
        with open(env_file) as f:
            for line in f:
                line = line.strip()
                if "=" in line and not line.startswith("#"):
                    k, v = line.split("=", 1)
                    existing[k] = v

    def mask(val):
        if len(val) <= 8:
            return val
        return val[:4] + "..." + val[-4:]

    keys = [
        ("ALPACA_API_KEY", "Alpaca API Key", ""),
        ("ALPACA_SECRET_KEY", "Alpaca Secret Key", ""),
        ("ALPACA_BASE_URL", "Alpaca Base URL", "https://paper-api.alpaca.markets"),
        ("FINNHUB_API_KEY", "Finnhub API Key (free at finnhub.io)", ""),
        ("FMP_API_KEY", "FMP API Key (optional fallback)", ""),
    ]

    print(f"\n  {BOLD}Configure API Keys{RESET}")
    print(f"  {DIM}Press Enter to keep existing value.{RESET}\n")

    values = {}
    for env_key, label, default in keys:
        cur = existing.get(env_key, default)
        if cur:
            display = f"{YELLOW}{mask(cur)}{RESET}"
        else:
            display = f"{DIM}(not set){RESET}"
        print(f"  {label}: {display}")
        new_val = input(f"  New value: ").strip()
        values[env_key] = new_val or cur
        print()

    with open(env_file, "w") as f:
        for env_key, _, _ in keys:
            f.write(f"{env_key}={values[env_key]}\n")

    print(f"  {GREEN}.env saved.{RESET}")


def cmd_logs(args):
    """Tail log files."""
    target = args[0] if args else "main"
    if target == "main":
        log_file = os.path.join(PROJECT_ROOT, "data", "logs", "main.log")
    elif target in ("txn", "transactions"):
        log_file = os.path.join(PROJECT_ROOT, "data", "logs", "transactions.log")
    elif target == "alerts":
        alerts_file = os.path.join(PROJECT_ROOT, "data", "logs", "alerts.json")
        if os.path.isfile(alerts_file):
            import json
            try:
                with open(alerts_file) as f:
                    data = json.load(f)
                print(json.dumps(data, indent=2))
            except (json.JSONDecodeError, ValueError):
                with open(alerts_file) as f:
                    print(f.read())
        else:
            print("  No alerts found.")
        return
    else:
        print(f"  Unknown log target: {target}")
        print(f"  Options: main, txn, alerts")
        return

    if not os.path.isfile(log_file):
        print(f"  Log file not found: {log_file}")
        return

    try:
        subprocess.run(["tail", "-f", log_file])
    except KeyboardInterrupt:
        pass


def cmd_db(args):
    """Query the SQLite database."""
    if not os.path.isfile(DB_PATH):
        print(f"  Database not found at {DB_PATH}")
        print(f"  Run: ./aitrade setup-db")
        return

    query_name = args[0] if args else "help"
    queries = {
        "positions": (
            "Open Positions",
            """SELECT ticker, qty, entry_price, stop_loss, take_profit, entry_time
               FROM positions WHERE status='open' ORDER BY entry_time DESC""",
        ),
        "closed": (
            "Closed Trades",
            """SELECT ticker, qty, entry_price, exit_price, pnl,
                      ROUND((exit_price - entry_price) / entry_price * 100, 1) AS pnl_pct,
                      exit_reason, exit_time
               FROM positions WHERE status='closed' ORDER BY exit_time DESC LIMIT 20""",
        ),
        "orders": (
            "Recent Orders",
            """SELECT ticker, side, qty, status, filled_price, submitted_at
               FROM orders ORDER BY submitted_at DESC LIMIT 20""",
        ),
        "portfolio": (
            "Portfolio History",
            """SELECT snapshot_time, total_value, cash, positions_value, peak_value
               FROM portfolio_snapshots ORDER BY snapshot_time DESC LIMIT 10""",
        ),
    }

    if query_name not in queries:
        print(f"  Unknown query: {query_name}")
        print(f"  Options: {', '.join(queries.keys())}")
        return

    title, sql = queries[query_name]
    conn = sqlite3.connect(DB_PATH)
    conn.execute("PRAGMA query_only = ON")
    cur = conn.execute(sql)
    cols = [d[0] for d in cur.description]
    rows = cur.fetchall()
    conn.close()

    if not rows:
        print(f"\n  {title}: (no data)")
        return

    # Format as table
    widths = [len(c) for c in cols]
    for row in rows:
        for i, val in enumerate(row):
            widths[i] = max(widths[i], len(str(val) if val is not None else ""))

    header = "  ".join(f"{c:<{widths[i]}}" for i, c in enumerate(cols))
    sep = "  ".join("-" * widths[i] for i in range(len(cols)))
    print(f"\n  {BOLD}{title}{RESET}\n")
    print(f"  {header}")
    print(f"  {sep}")
    for row in rows:
        line = "  ".join(
            f"{(str(v) if v is not None else ''):<{widths[i]}}"
            for i, v in enumerate(row)
        )
        print(f"  {line}")
    print()


